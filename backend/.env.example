# ─────────────────────────────────────────────────────────────────────────────
# Variáveis de ambiente do backend da Proposta (Maria Films).
# COPIE este arquivo para `backend/.env` e preencha os valores reais.
# O `.env` NÃO vai pro git (está no .gitignore) — trate cada valor como senha.
# O main.py carrega o .env sozinho no startup (python-dotenv).
# ─────────────────────────────────────────────────────────────────────────────

# ── Autentique (assinatura eletrônica) ──────────────────────────────────────
# Token da conta (fica SÓ no servidor, nunca no front).
AUTENTIQUE_TOKEN=
# sandbox=true não gasta crédito e o doc some sozinho. Em produção: false.
AUTENTIQUE_SANDBOX=true
# Segredo do webhook (HMAC). Defina o MESMO valor aqui e no painel da Autentique.
AUTENTIQUE_WEBHOOK_SECRET=
# Stand-in da contratada p/ teste (evita o 3º signatário fantasma). Em produção,
# use a conta/e-mail reais da Maria e remova estes.
CONTRATADA_EMAIL=
CONTRATADA_NOME=

# ── Supabase (Postgres + Storage) ───────────────────────────────────────────
SUPABASE_URL=
# service_role key — BYPASSA o RLS. Tratar como senha; rotacionar em produção.
SUPABASE_SERVICE_KEY=

# ── Admin (/admin do site) ──────────────────────────────────────────────────
ADMIN_TOKEN=maria-admin-2026

# ── Gateway de pagamento (Mercado Pago) — Fase 2, ainda não implementado ─────
MERCADOPAGO_ACCESS_TOKEN=
GATEWAY_WEBHOOK_SECRET=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Domínios do front separados por vírgula. Default = dev local.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
